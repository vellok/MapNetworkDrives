<Window x:Class="MapNetworkDrives.CredentialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Network Credentials" Height="280" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="11"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="LightBorderBrush" Color="#D0D0D0"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource LightBorderBrush}" BorderThickness="0,0,0,1" Padding="15,15">
            <TextBlock Text="Network Credentials Required" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
        </Border>

        <!-- Form -->
        <StackPanel DockPanel.Dock="Top" Margin="20,20" Spacing="12">

            <StackPanel>
                <Label Content="Username (e.g., DOMAIN\user):" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameTextBox" Height="32"/>
                <TextBlock Text="Enter your domain and username" FontSize="9" Foreground="#999999" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel>
                <Label Content="Password:" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Height="32"/>
            </StackPanel>

            <!-- Info Box -->
            <Border Background="#E7F3FF" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" CornerRadius="4" Padding="10">
                <TextBlock Text="ℹ Your credentials will only be used for this drive mapping session and will not be saved." 
                           FontSize="9" Foreground="#0078D4" TextWrapping="Wrap"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="OkButton" Content="OK" Style="{StaticResource ModernButtonStyle}" Width="80" Margin="0,0,10,0"/>
                <Button x:Name="CancelButton" Content="Cancel" Background="A0A0A0" Foreground="White" FontWeight="SemiBold" Padding="12,8" Width="80" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
