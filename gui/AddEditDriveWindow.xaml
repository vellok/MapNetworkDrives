<Window x:Class="MapNetworkDrives.AddEditDriveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Drive" Height="340" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="11"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="LightBorderBrush" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFB900"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource LightBorderBrush}" BorderThickness="0,0,0,1" Padding="15,15">
            <StackPanel>
                <TextBlock x:Name="WindowTitleBlock" Text="Add New Network Drive" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Enter drive letter and network path" FontSize="10" Foreground="#666666" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel DockPanel.Dock="Top" Margin="20,20" Spacing="14">

            <!-- Drive Letter -->
            <StackPanel>
                <Label Content="Drive Letter (A-Z):" Margin="0,0,0,4"/>
                <TextBox x:Name="DriveLetterTextBox" MaxLength="2" Text="Z"/>
                <TextBlock Text="Enter a single letter (e.g., Z) without colon" FontSize="9" Foreground="#999999" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Network Path -->
            <StackPanel>
                <Label Content="Network Path (UNC):" Margin="0,0,0,4"/>
                <TextBox x:Name="NetworkPathTextBox" Text="\\server\share\folder"/>
                <TextBlock Text="Format: \\servername\share or \\servername\share\folder" FontSize="9" Foreground="#999999" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Warning Box -->
            <Border Background="#FFF8DC" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,5,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" Margin="0,0,8,0" FontSize="13"/>
                    <TextBlock Text="Path must be accessible from your network" FontSize="9" Foreground="#8B6914" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="SaveButton" Content="OK" Style="{StaticResource ModernButtonStyle}" Width="80" Margin="0,0,10,0"/>
                <Button x:Name="CancelButton" Content="Cancel" Background="A0A0A0" Foreground="White" FontWeight="SemiBold" Padding="12,8" Width="80" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
